# Aegis AI Firewall — Environment Configuration
# Copy this file to .env and fill in values as needed.

# LLM provider: "mock" (default), "openai", or "anthropic"
LLM_PROVIDER=mock

# Required only when LLM_PROVIDER=openai
OPENAI_API_KEY=

# Required only when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# FPE Encryption Keys (generate with: python -c "import secrets; print(secrets.token_hex(32))")
FPE_KEY=your-64-char-hex-key-here
FPE_TWEAK=your-14-char-hex-tweak-here

# Weilliptic Applet Configuration
# Required for on-chain audit mode
WEIL_PRIVATE_KEY=
WEIL_APPLET_ADDRESS=
